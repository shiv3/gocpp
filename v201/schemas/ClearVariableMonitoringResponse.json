{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "additionalProperties": false,
  "comment": "OCPP 2.0.1 FINAL",
  "definitions": {
    "ClearMonitoringResultType": {
      "additionalProperties": false,
      "javaType": "ClearMonitoringResult",
      "properties": {
        "customData": {
          "$ref": "#/definitions/CustomDataType"
        },
        "id": {
          "description": "Id of the monitor of which a clear was requested.\r\n\r\n",
          "minimum": 0,
          "type": "integer"
        },
        "status": {
          "$ref": "#/definitions/ClearMonitoringStatusEnumType"
        },
        "statusInfo": {
          "$ref": "#/definitions/StatusInfoType"
        }
      },
      "required": [
        "status",
        "id"
      ],
      "type": "object"
    },
    "ClearMonitoringStatusEnumType": {
      "additionalProperties": false,
      "description": "Result of the clear request for this monitor, identified by its Id.\r\n\r\n",
      "enum": [
        "Accepted",
        "Rejected",
        "NotFound"
      ],
      "javaType": "ClearMonitoringStatusEnum",
      "type": "string"
    },
    "CustomDataType": {
      "description": "This class does not get 'AdditionalProperties = false' in the schema generation, so it can be extended with arbitrary JSON properties to allow adding custom data.",
      "javaType": "CustomData",
      "properties": {
        "vendorId": {
          "maxLength": 255,
          "type": "string"
        }
      },
      "required": [
        "vendorId"
      ],
      "type": "object"
    },
    "StatusInfoType": {
      "additionalProperties": false,
      "description": "Element providing more information about the status.\r\n",
      "javaType": "StatusInfo",
      "properties": {
        "additionalInfo": {
          "description": "Additional text to provide detailed information.\r\n",
          "maxLength": 512,
          "type": "string"
        },
        "customData": {
          "$ref": "#/definitions/CustomDataType"
        },
        "reasonCode": {
          "description": "A predefined code for the reason why the status is returned in this response. The string is case-insensitive.\r\n",
          "maxLength": 20,
          "type": "string"
        }
      },
      "required": [
        "reasonCode"
      ],
      "type": "object"
    }
  },
  "properties": {
    "clearMonitoringResult": {
      "additionalItems": false,
      "items": {
        "$ref": "#/definitions/ClearMonitoringResultType"
      },
      "minItems": 1,
      "type": "array"
    },
    "customData": {
      "$ref": "#/definitions/CustomDataType"
    }
  },
  "required": [
    "clearMonitoringResult"
  ],
  "type": "object"
}