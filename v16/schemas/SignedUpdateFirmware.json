{
  "$id": "urn:OCPP:Cp:1.6:2020:3:SignedUpdateFirmware.req",
  "$schema": "http://json-schema.org/draft-06/schema#",
  "additionalProperties": false,
  "definitions": {
    "FirmwareType": {
      "additionalProperties": false,
      "properties": {
        "installDateTime": {
          "format": "date-time",
          "type": "string"
        },
        "location": {
          "maxLength": 512,
          "type": "string"
        },
        "retrieveDateTime": {
          "format": "date-time",
          "type": "string"
        },
        "signature": {
          "maxLength": 800,
          "type": "string"
        },
        "signingCertificate": {
          "maxLength": 5500,
          "type": "string"
        }
      },
      "required": [
        "location",
        "retrieveDateTime",
        "signingCertificate",
        "signature"
      ],
      "type": "object"
    }
  },
  "properties": {
    "firmware": {
      "$ref": "#/definitions/FirmwareType"
    },
    "requestId": {
      "minimum": 0,
      "type": "integer"
    },
    "retries": {
      "minimum": 0,
      "type": "integer"
    },
    "retryInterval": {
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "requestId",
    "firmware"
  ],
  "type": "object"
}