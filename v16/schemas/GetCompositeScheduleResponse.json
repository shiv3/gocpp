{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "additionalProperties": false,
  "properties": {
    "chargingSchedule": {
      "additionalProperties": false,
      "properties": {
        "chargingRateUnit": {
          "additionalProperties": false,
          "enum": [
            "A",
            "W"
          ],
          "type": "string"
        },
        "chargingSchedulePeriod": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "limit": {
                "multipleOf": 0.1,
                "type": "number"
              },
              "numberPhases": {
                "type": "integer"
              },
              "startPeriod": {
                "type": "integer"
              }
            },
            "required": [
              "startPeriod",
              "limit"
            ],
            "type": "object"
          },
          "minItems": 1,
          "type": "array"
        },
        "duration": {
          "type": "integer"
        },
        "minChargingRate": {
          "multipleOf": 0.1,
          "type": "number"
        },
        "startSchedule": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "chargingRateUnit",
        "chargingSchedulePeriod"
      ],
      "type": "object"
    },
    "connectorId": {
      "minimum": 0,
      "type": "integer"
    },
    "scheduleStart": {
      "format": "date-time",
      "type": "string"
    },
    "status": {
      "additionalProperties": false,
      "enum": [
        "Accepted",
        "Rejected"
      ],
      "type": "string"
    }
  },
  "required": [
    "status"
  ],
  "title": "GetCompositeScheduleResponse",
  "type": "object"
}