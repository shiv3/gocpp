{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "additionalProperties": false,
  "properties": {
    "currentTime": {
      "format": "date-time",
      "type": "string"
    },
    "interval": {
      "minimum": 0,
      "type": "integer"
    },
    "status": {
      "additionalProperties": false,
      "enum": [
        "Accepted",
        "Pending",
        "Rejected"
      ],
      "type": "string"
    }
  },
  "required": [
    "status",
    "currentTime",
    "interval"
  ],
  "title": "BootNotificationResponse",
  "type": "object"
}