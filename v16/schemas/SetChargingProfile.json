{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "additionalProperties": false,
  "properties": {
    "connectorId": {
      "minimum": 0,
      "type": "integer"
    },
    "csChargingProfiles": {
      "additionalProperties": false,
      "properties": {
        "chargingProfileId": {
          "type": "integer"
        },
        "chargingProfileKind": {
          "additionalProperties": false,
          "enum": [
            "Absolute",
            "Recurring",
            "Relative"
          ],
          "type": "string"
        },
        "chargingProfilePurpose": {
          "additionalProperties": false,
          "enum": [
            "ChargePointMaxProfile",
            "TxDefaultProfile",
            "TxProfile"
          ],
          "type": "string"
        },
        "chargingSchedule": {
          "additionalProperties": false,
          "properties": {
            "chargingRateUnit": {
              "additionalProperties": false,
              "enum": [
                "A",
                "W"
              ],
              "type": "string"
            },
            "chargingSchedulePeriod": {
              "items": {
                "additionalProperties": false,
                "properties": {
                  "limit": {
                    "multipleOf": 0.1,
                    "type": "number"
                  },
                  "numberPhases": {
                    "type": "integer"
                  },
                  "startPeriod": {
                    "type": "integer"
                  }
                },
                "required": [
                  "startPeriod",
                  "limit"
                ],
                "type": "object"
              },
              "minItems": 1,
              "type": "array"
            },
            "duration": {
              "type": "integer"
            },
            "minChargingRate": {
              "multipleOf": 0.1,
              "type": "number"
            },
            "startSchedule": {
              "format": "date-time",
              "type": "string"
            }
          },
          "required": [
            "chargingRateUnit",
            "chargingSchedulePeriod"
          ],
          "type": "object"
        },
        "recurrencyKind": {
          "additionalProperties": false,
          "enum": [
            "Daily",
            "Weekly"
          ],
          "type": "string"
        },
        "stackLevel": {
          "type": "integer"
        },
        "transactionId": {
          "type": "integer"
        },
        "validFrom": {
          "format": "date-time",
          "type": "string"
        },
        "validTo": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "chargingProfileId",
        "stackLevel",
        "chargingProfilePurpose",
        "chargingProfileKind",
        "chargingSchedule"
      ],
      "type": "object"
    }
  },
  "required": [
    "connectorId",
    "csChargingProfiles"
  ],
  "title": "SetChargingProfileRequest",
  "type": "object"
}