{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "additionalProperties": false,
  "properties": {
    "listVersion": {
      "minimum": 0,
      "type": "integer"
    },
    "localAuthorizationList": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "idTag": {
            "maxLength": 20,
            "type": "string"
          },
          "idTagInfo": {
            "additionalProperties": false,
            "properties": {
              "expiryDate": {
                "format": "date-time",
                "type": "string"
              },
              "parentIdTag": {
                "maxLength": 20,
                "type": "string"
              },
              "status": {
                "additionalProperties": false,
                "enum": [
                  "Accepted",
                  "Blocked",
                  "Expired",
                  "Invalid",
                  "ConcurrentTx"
                ],
                "type": "string"
              }
            },
            "required": [
              "status"
            ],
            "type": "object"
          }
        },
        "required": [
          "idTag"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "updateType": {
      "additionalProperties": false,
      "enum": [
        "Differential",
        "Full"
      ],
      "type": "string"
    }
  },
  "required": [
    "listVersion",
    "updateType"
  ],
  "title": "SendLocalListRequest",
  "type": "object"
}