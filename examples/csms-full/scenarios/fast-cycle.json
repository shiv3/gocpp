{
  "id": "fast-cycle",
  "name": "Fast Full Cycle (OCPP 1.6)",
  "description": "Compressed Boot -> StatusNotification -> (CSMS RemoteStartTransaction) -> StartTransaction -> a few MeterValues -> StopTransaction lifecycle. Uses a 1s meter interval and a small maxValue so the whole charging session completes in a few seconds, exercising every gocpp CSMS handler (including StopTransaction) within a short interop window.",
  "targetType": "connector",
  "targetId": 1,
  "trigger": { "type": "manual" },
  "defaultExecutionMode": "oneshot",
  "enabled": true,
  "nodes": [
    {
      "id": "start",
      "type": "start",
      "position": { "x": 400, "y": 0 },
      "data": { "label": "Start on connect", "triggerOn": "connect" }
    },
    {
      "id": "wait-boot",
      "type": "delay",
      "position": { "x": 400, "y": 100 },
      "data": { "label": "Wait for BootNotification.conf", "delaySeconds": 1 }
    },
    {
      "id": "await-remote-start",
      "type": "remoteStartTrigger",
      "position": { "x": 400, "y": 200 },
      "data": { "label": "Wait for RemoteStartTransaction", "timeout": 0 }
    },
    {
      "id": "start-tx",
      "type": "transaction",
      "position": { "x": 400, "y": 300 },
      "data": { "label": "StartTransaction.req", "action": "start", "tagId": "TAG001" }
    },
    {
      "id": "status-charging",
      "type": "statusChange",
      "position": { "x": 400, "y": 400 },
      "data": { "label": "Set Charging", "status": "Charging" }
    },
    {
      "id": "auto-meter",
      "type": "meterValue",
      "position": { "x": 400, "y": 500 },
      "data": {
        "label": "MeterValues (fast, capped)",
        "value": 0,
        "sendMessage": true,
        "autoIncrement": true,
        "incrementInterval": 1,
        "incrementAmount": 1000,
        "maxValue": 4000
      }
    },
    {
      "id": "stop-tx",
      "type": "transaction",
      "position": { "x": 400, "y": 600 },
      "data": { "label": "StopTransaction.req", "action": "stop" }
    },
    {
      "id": "end",
      "type": "end",
      "position": { "x": 400, "y": 700 },
      "data": { "label": "End" }
    }
  ],
  "edges": [
    { "id": "e1", "source": "start", "target": "wait-boot" },
    { "id": "e2", "source": "wait-boot", "target": "await-remote-start" },
    { "id": "e3", "source": "await-remote-start", "target": "start-tx" },
    { "id": "e4", "source": "start-tx", "target": "status-charging" },
    { "id": "e5", "source": "status-charging", "target": "auto-meter" },
    { "id": "e6", "source": "auto-meter", "target": "stop-tx" },
    { "id": "e7", "source": "stop-tx", "target": "end" }
  ]
}
